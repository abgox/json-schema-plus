{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "node esbuild.mjs",
			"problemMatcher": "$esbuild",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch",
			"type": "shell",
			"command": "node esbuild.mjs --watch",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "build start",
					"endsPattern": "build finished"
				}
			},
			"presentation": {
				"reveal": "never"
			}
		}
	]
}
