{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/dist/**/*.js"
			],
			"preLaunchTask": "build"
		},
		{
			"name": "Run Web Extension",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "node",
			"program": "${workspaceFolder}/node_modules/@vscode/test-web/out/server/index.js",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"--browser",
				"none",
				"--port",
				"8080"
			],
			"preLaunchTask": "watch"
		}
	]
}
